---
import type { GetStaticPaths } from 'astro';
import { shouldShowContent } from '@/utils/markdown';
import { getLocalisedPages, pageSlug } from '@/utils/i18n';
import PageLayout from '@/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  // EN pages only (i18n: see docs/XDD/adr/ADR-002).
  // DE pages and special-page fallbacks are served by src/pages/[...slug].astro.
  const pages = await getLocalisedPages('en');

  const isDev = import.meta.env.DEV;
  const visiblePages = pages.filter(page => shouldShowContent(page, isDev));

  // Strip the en/ folder prefix so URLs are /en/<slug>/, not /en/en/<slug>/.
  return visiblePages.map(page => ({
    params: { slug: pageSlug(page) },
    props: { page }
  }));
};

export interface Props {
  page: any;
}

const { page } = Astro.props;

if (!page) {
  return Astro.redirect('/404');
}

const isDev = import.meta.env.DEV;
if (!shouldShowContent(page, isDev)) {
  return Astro.redirect('/404');
}
---

<PageLayout page={page} />
