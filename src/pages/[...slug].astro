---
import type { GetStaticPaths } from 'astro';
import { shouldShowContent } from '@/utils/markdown';
import { getLocalisedPages, pageSlug } from '@/utils/i18n';
import PageLayout from '@/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  // Get DE pages only (i18n: see docs/XDD/adr/ADR-002).
  // EN pages are served by src/pages/[locale]/[...slug].astro.
  const pages = await getLocalisedPages('de');

  // Filter pages based on environment (in dev, show all including drafts)
  const isDev = import.meta.env.DEV;
  const visiblePages = pages.filter(page => shouldShowContent(page, isDev));

  // Generate paths — strip the de/ folder prefix so URLs are /<slug>/,
  // not /de/<slug>/. (Symmetric folder layout, see ADR-002.)
  const pagePaths = visiblePages.map(page => ({
    params: { slug: pageSlug(page) },
    props: { page }
  }));

  // Special pages are routed by their dedicated handlers (homepage, 404, posts/,
  // projects/, docs/). They are NOT emitted as standalone routes by [...slug].astro
  // since ADR-005 Phase C (2026-05-12) — the special collection only carries
  // fragment content for those routes, never standalone URLs.
  return pagePaths;
};

export interface Props {
  page: any;
}

const { page } = Astro.props;

// Validate page data
if (!page) {
  return Astro.redirect('/404');
}

// Check if page should be visible (handles drafts in production)
const isDev = import.meta.env.DEV;
if (!shouldShowContent(page, isDev)) {
  return Astro.redirect('/404');
}
---

<PageLayout page={page} />
