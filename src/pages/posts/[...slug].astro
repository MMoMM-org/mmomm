---
import type { GetStaticPaths } from 'astro';
import { shouldShowPost } from '@/utils/markdown';
import { getLocalisedPosts, postSlug } from '@/utils/i18n';
import PostLayout from '@/layouts/PostLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  // Get DE posts only (i18n: see docs/XDD/adr/ADR-002)
  const posts = await getLocalisedPosts('de');

  // Filter posts for production (in dev, show all including drafts)
  const isDev = import.meta.env.DEV;
  const visiblePosts = posts.filter(post => shouldShowPost(post, isDev));

  // Generate paths — strip the de/ folder prefix so URLs are /posts/<slug>/,
  // not /posts/de/<slug>/. (Symmetric folder layout, see ADR-002.)
  return visiblePosts.map(post => ({
    params: { slug: postSlug(post) },
    props: { post }
  }));
};

export interface Props {
  post: any;
}

const { post } = Astro.props;

// Validate post data
if (!post) {
  return Astro.redirect('/404');
}

// Check if post should be visible in production
const isDev = import.meta.env.DEV;
if (!shouldShowPost(post, isDev)) {
  return Astro.redirect('/404');
}
---

<PostLayout post={post} />
